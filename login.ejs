<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Student Management System</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * {
      font-family: 'Inter', sans-serif;
      box-sizing: border-box;
    }
    body {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100vh;
      margin: 0;
      background: #F4F7FE;
    }
    .login-card {
      background: #fff;
      padding: 50px 40px;
      border-radius: 24px;
      box-shadow: 0 20px 60px rgba(43, 54, 116, 0.08);
      max-width: 420px;
      width: 100%;
    }
    .logo-box {
      width: 50px;
      height: 50px;
      margin: 0 auto 20px auto;
      background: linear-gradient(135deg, #FF9C00, #FFC048);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-weight: 700;
      font-size: 22px;
    }
    h3.welcome-title {
      text-align: center;
      font-weight: 700;
      color: #2B3674;
      margin-bottom: 4px;
    }
    p.welcome-subtext {
      text-align: center;
      color: #A3AED0;
      margin-bottom: 30px;
      font-size: 14px;
    }
    .form-control {
      background: #F8FAFC;
      border: 1px solid #E9EDF7;
      border-radius: 12px;
      padding: 12px 16px;
      font-size: 14px;
    }
    .form-control:focus {
      border-color: #6366F1;
      box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.12);
      background: #fff;
    }
    label {
      font-size: 13px;
      font-weight: 600;
      color: #2B3674;
      margin-bottom: 6px;
    }
    .btn-signin {
      background: #6366F1;
      border: none;
      border-radius: 12px;
      padding: 12px;
      width: 100%;
      color: #fff;
      font-weight: 600;
      font-size: 15px;
      margin-top: 10px;
      transition: background 0.2s ease;
    }
    .btn-signin:hover {
      background: #4F46E5;
      color: #fff;
    }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="logo-box">S</div>
    <h3 class="welcome-title">Welcome Back</h3>
    <p class="welcome-subtext">Student Management System</p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger" role="alert">
        <%= error %>
      </div>
    <% } %>

    <form action="/login" method="POST">
      <div class="mb-3">
        <label for="email" class="form-label">Email Address</label>
        <input type="text" class="form-control" id="email" name="email" placeholder="you@example.com" required>
      </div>
      <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <input type="password" class="form-control" id="password" name="password" placeholder="••••••••" required>
      </div>
      <button type="submit" class="btn btn-signin">Sign In</button>
    </form>
  </div>
</body>
</html>
